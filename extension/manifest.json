{
  "manifest_version": 3,
  "name": "GuardMedia Real-Time Scanner",
  "version": "1.0",
  "description": "AI-Powered media verification for real-time asset protection.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*", "<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "48": "icon.png"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
